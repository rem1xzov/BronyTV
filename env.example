# Copy to .env next to docker-compose.yml (no quotes, no spaces around values).
POSTGRES_USER=postgres
POSTGRES_PASSWORD=123456
POSTGRES_DB=BronyTV

# Origin allowed to send credentialed requests (session cookie).
# For production over HTTP/IP set this to your public frontend URL, e.g.:
# FRONTEND_ORIGIN=http://132.243.114.41:8080
FRONTEND_ORIGIN=http://localhost:8080
